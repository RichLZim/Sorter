<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark industrial theme with amber accents -->
    <Style Selector="Window">
        <Setter Property="Background" Value="#0D0F14"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="#C8D0DC"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#161A22"/>
        <Setter Property="Foreground" Value="#E8C55A"/>
        <Setter Property="BorderBrush" Value="#2A3040"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="#E8C55A"/>
    </Style>

    <Style Selector="Button.Primary">
        <Setter Property="Background" Value="#E8C55A"/>
        <Setter Property="Foreground" Value="#0D0F14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#F0D070"/>
    </Style>

    <Style Selector="Button.Primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#C8A840"/>
    </Style>

    <Style Selector="Button.Primary:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="#3A3020"/>
        <Setter Property="TextElement.Foreground" Value="#6A6040"/>
    </Style>

    <Style Selector="Button.Secondary">
        <Setter Property="Background" Value="#1E2430"/>
        <Setter Property="Foreground" Value="#C8D0DC"/>
        <Setter Property="BorderBrush" Value="#2A3040"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#252D3A"/>
        <Setter Property="BorderBrush" Value="#E8C55A"/>
    </Style>

    <Style Selector="Button.Danger">
        <Setter Property="Background" Value="#2A1515"/>
        <Setter Property="Foreground" Value="#E05050"/>
        <Setter Property="BorderBrush" Value="#3A2020"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="#C8D0DC"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="CheckBox /template/ Border#NormalRectangle">
        <Setter Property="BorderBrush" Value="#3A4050"/>
        <Setter Property="Background" Value="#161A22"/>
    </Style>

    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="#E8C55A"/>
        <Setter Property="BorderBrush" Value="#E8C55A"/>
    </Style>

    <Style Selector="ProgressBar">
        <Setter Property="Background" Value="#161A22"/>
        <Setter Property="Foreground" Value="#E8C55A"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Height" Value="4"/>
    </Style>

    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="Border.Card">
        <Setter Property="Background" Value="#131720"/>
        <Setter Property="BorderBrush" Value="#1E2430"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style Selector="Border.SectionHeader">
        <Setter Property="Background" Value="#0D1018"/>
        <Setter Property="BorderBrush" Value="#1E2430"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="16,10"/>
    </Style>

    <Style Selector="TextBlock.Label">
        <Setter Property="Foreground" Value="#6A7888"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBlock.Value">
        <Setter Property="Foreground" Value="#E8C55A"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBlock.Heading">
        <Setter Property="Foreground" Value="#E8F0FC"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBlock.Status">
        <Setter Property="Foreground" Value="#4A8080"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBlock.Error">
        <Setter Property="Foreground" Value="#E05050"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBlock.Success">
        <Setter Property="Foreground" Value="#50C080"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="ListBox">
        <Setter Property="Background" Value="#0D0F14"/>
        <Setter Property="BorderBrush" Value="#1E2430"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#8090A0"/>
    </Style>

    <!-- Log entries wrap within their container width -->
    <Style Selector="ListBoxItem > TextBlock">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#1A2030"/>
    </Style>

    <Style Selector="Separator">
        <Setter Property="Background" Value="#1E2430"/>
        <Setter Property="Height" Value="1"/>
    </Style>


    <!-- ── Backend selector buttons ── -->
    <!-- Active state: bright green -->
    <Style Selector="Button.BackendActive">
        <Setter Property="Background"   Value="#1E5C1E"/>
        <Setter Property="Foreground"   Value="#80FF80"/>
        <Setter Property="BorderBrush"  Value="#40A040"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontFamily"   Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="Cursor"       Value="Hand"/>
    </Style>

    <!-- Idle / not-installed state: dim grey with a subtle pulse animation -->
    <Style Selector="Button.BackendIdle">
        <Setter Property="Background"   Value="#181E18"/>
        <Setter Property="Foreground"   Value="#4A5A4A"/>
        <Setter Property="BorderBrush"  Value="#252D25"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontFamily"   Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Style.Animations>
            <Animation Duration="0:0:1.6" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0.55"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1.0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Custom button (always visible, purple tint) -->
    <Style Selector="Button.BackendCustomActive">
        <Setter Property="Background"   Value="#22184A"/>
        <Setter Property="Foreground"   Value="#B090FF"/>
        <Setter Property="BorderBrush"  Value="#5040A0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontFamily"   Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="Cursor"       Value="Hand"/>
    </Style>

    <Style Selector="Button.BackendCustomIdle">
        <Setter Property="Background"   Value="#12101E"/>
        <Setter Property="Foreground"   Value="#5848A0"/>
        <Setter Property="BorderBrush"  Value="#201C3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="FontFamily"   Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Style.Animations>
            <Animation Duration="0:0:1.6" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.5"/></KeyFrame>
                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>