<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sorter.ViewModels"
        xmlns:conv="using:Avalonia.Data.Converters"
        x:Class="Sorter.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Sorterz — AI Image Organizer"
        Width="1200" Height="720"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0D0F14"
        Icon="/Assets/Icon.ico">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto" Margin="20,14">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14">
                    <Image Source="/Assets/logo64.png" Height="32" Width="32"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SORTER" Classes="Heading" FontSize="20"/>
                        <TextBlock Text="AI-POWERED IMAGE ORGANIZER" Classes="Label" FontSize="11" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="300,*,300">

            <!-- ═══ LEFT PANEL: CONTROLS ═══ -->
            <Border Grid.Column="0" Background="#0D0F14" BorderBrush="#1E2430" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" Spacing="14">

                        <!-- FOLDERS CARD -->
                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="FOLDERS" Classes="Label"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="SOURCE (to sort)" Classes="Label" FontSize="10"/>
                                    <Grid ColumnDefinitions="*,6,Auto">
                                        <TextBox Text="{Binding Settings.SortingFolder}" Grid.Column="0" Watermark="C:\path\to\source..."/>
                                        <Button Grid.Column="2" Content="···" Classes="Secondary" Padding="10,6" Command="{Binding BrowseSourceCommand}"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="OUTPUT (sorted into)" Classes="Label" FontSize="10"/>
                                    <Grid ColumnDefinitions="*,6,Auto">
                                        <TextBox Text="{Binding Settings.SortedFolder}" Grid.Column="0" Watermark="C:\path\to\output..."/>
                                        <Button Grid.Column="2" Content="···" Classes="Secondary" Padding="10,6" Command="{Binding BrowseOutputCommand}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- RENAME OPTIONS CARD -->
                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="RENAME OPTIONS" Classes="Label"/>
                                <StackPanel Spacing="6">
                                    <CheckBox IsChecked="{Binding Settings.UsePrefix}" Content="Use Prefix on Rename"/>
                                    <StackPanel Spacing="4" IsVisible="{Binding Settings.UsePrefix}">
                                        <TextBlock Text="PREFIX (max 8 chars)" Classes="Label" FontSize="10"/>
                                        <TextBox Text="{Binding Settings.Prefix}" MaxLength="8" Watermark="IMG"/>
                                        <TextBlock Text="Format: PREFIX.YEAR.MM.DD.three.word.desc.ext" Classes="Status" FontSize="10" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock Text="Format: YEAR.MM.DD.three.word.desc.ext" Classes="Status" FontSize="10" TextWrapping="Wrap"
                                               IsVisible="{Binding Settings.UsePrefix, Converter={x:Static conv:BoolConverters.Not}}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- FILTER OPTIONS CARD -->
                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="FILTER OPTIONS" Classes="Label"/>
                                <CheckBox IsChecked="{Binding Settings.IgnoreNonDatedFiles}" Content="Ignore non-dated files"/>
                                <TextBlock Text="Skips files with no date in 2001–2099 range" Classes="Status" FontSize="10" Margin="24,0,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- IMAGE PREVIEW CARD -->
                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="CURRENT IMAGE PREVIEW" Classes="Label"/>
                                <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="4" ClipToBounds="True" Height="250" Background="#1A1C23">
                                    <Panel>
                                        <TextBlock Text="No Image Loaded" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#444444" FontSize="11"
                                                   IsVisible="{Binding Preview.HasImage, Converter={x:Static conv:BoolConverters.Not}}"/>
                                        <Image Source="{Binding Preview.CurrentImageSource}" Stretch="Uniform"/>
                                    </Panel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══ MIDDLE PANEL: PROMPT + LOG + RESULTS ═══ -->
            <Grid Grid.Column="1" RowDefinitions="160,4,*,Auto,180">
                <Border Grid.Row="0" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,0,0,1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="SectionHeader" Grid.Row="0">
                            <Grid ColumnDefinitions="Auto,15,Auto,*,Auto">
                                <CheckBox Grid.Column="0" IsChecked="{Binding Settings.UseCustomPrompt}" Content="CUSTOM PROMPT" FontFamily="Consolas,'Courier New',monospace" FontSize="11" Foreground="#6A7888" VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="2" IsChecked="{Binding Settings.UseVrcPreset}" Content="VRCHAT PRESET" FontFamily="Consolas,'Courier New',monospace" FontSize="11" Foreground="#9A70D0" VerticalAlignment="Center">
                                    <CheckBox.Styles>
                                        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                                            <Setter Property="Background" Value="#9A70D0"/>
                                            <Setter Property="BorderBrush" Value="#9A70D0"/>
                                        </Style>
                                    </CheckBox.Styles>
                                </CheckBox>
                                <TextBlock Grid.Column="4" Text="(default shown when off)" Classes="Status" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding Settings.IsDefaultPromptActive}"/>
                            </Grid>
                        </Border>
                        <Panel Grid.Row="1">
                            <TextBox Text="{Binding Settings.ActivePromptText, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" IsEnabled="{Binding Settings.UseCustomPrompt}" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="#0A0C10" Foreground="#C8D0DC" BorderThickness="0" Padding="12,8" FontSize="11" FontFamily="Consolas,'Courier New',monospace"/>
                            <Border Background="#0A0C10" Opacity="0.65" IsHitTestVisible="False" IsVisible="{Binding Settings.UseCustomPrompt, Converter={x:Static conv:BoolConverters.Not}}"/>
                        </Panel>
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" ResizeDirection="Rows" Background="#1E2430" HorizontalAlignment="Stretch" Height="4"/>

                <Border Grid.Row="2" Background="#0A0C10">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="SectionHeader" Grid.Row="0">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Text="ACTIVITY LOG" Classes="Label" VerticalAlignment="Center" Grid.Column="0"/>
                                <Button Grid.Column="1" Content="CLEAR" Classes="Secondary" Padding="8,3" FontSize="11" Command="{Binding ClearLogCommand}" Margin="0,0,5,0"/>
                                <Button Grid.Column="2" Content="RESET SETTINGS" Classes="Secondary" Padding="8,3" FontSize="11" Command="{Binding ResetSettingsCommand}"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding Progress.LogEntries}" Background="Transparent" BorderThickness="0" Margin="0"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#0D0F14" Padding="16,8">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <ProgressBar Grid.Row="0" Grid.ColumnSpan="2" Minimum="0" Maximum="100" Value="{Binding Progress.ProgressValue}" Height="6" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Progress.StatusText}" Classes="Status" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Progress.ProgressText}" Classes="Value" FontSize="11"/>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,1,0,0">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="SectionHeader" Grid.Row="0">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="PROCESSED FILES" Classes="Label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Progress.ResultCountText}" Grid.Column="1" Classes="Value" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding Progress.ProcessedFiles}" Background="Transparent" BorderThickness="0"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ RIGHT PANEL: LLM MODULE SETTINGS ═══ -->
            <Border Grid.Column="2" Background="#0D0F14" BorderBrush="#1E2430" BorderThickness="1,0,0,1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" Spacing="14">
                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="CONNECTION" Classes="Label"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Fill="{Binding Connection.ConnectionColor}"/>
                                    <TextBlock Text="{Binding Connection.ConnectionStatusText}" Classes="Label" FontSize="10"/>
                                </StackPanel>
                                <Button Content="TEST CONNECTION" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding TestConnectionCommand}"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="SERVER CONTROL" Classes="Label"/>
                                <Button Content="{Binding Connection.ServerButtonText}" Background="{Binding Connection.ServerButtonBackground}" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding LoadLmStudioCommand}"/>
                                <Button Content="STOP SERVER" Classes="Danger" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding StopServerCommand}"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="MODEL SELECTION" Classes="Label"/>
                                <ComboBox SelectedItem="{Binding Settings.SelectedModel}" ItemsSource="{Binding Settings.AvailableModels}" HorizontalAlignment="Stretch" FontSize="11" Background="#161A22" Foreground="#E8C55A">
                                    <ComboBox.Styles>
                                        <Style Selector="ComboBoxItem">
                                            <Setter Property="Foreground" Value="#C8D0DC"/>
                                        </Style>
                                    </ComboBox.Styles>
                                </ComboBox>
                                <Button Content="INSTALL SELECTED MODEL" Background="#228B22" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding InstallLmStudioCommand}"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="LLM HOSTNAME (IP)" Classes="Label"/>
                                <TextBox Text="{Binding Settings.LmStudioUrl}" FontSize="11" Padding="8,6" Background="#161A22" BorderBrush="#2A3040"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <CheckBox IsChecked="{Binding Settings.ShowTokenCost}" Content="Show Token Cost / Speed"/>
                                <Border Background="#0D0F14" BorderBrush="#1E2430" BorderThickness="1" CornerRadius="4" Padding="10,8" IsVisible="{Binding Settings.ShowTokenCost}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="INPUT TOKENS" Classes="Label" FontSize="10" Margin="0,0,0,6"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Progress.InputTokens}" Classes="Value" FontSize="12"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="OUTPUT TOKENS" Classes="Label" FontSize="10" Margin="0,0,0,6"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Progress.OutputTokens}" Classes="Value" FontSize="12"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="SPEED (t/s)" Classes="Label" FontSize="10" Margin="0,0,0,6"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Progress.TokensPerSecond}" Classes="Value" FontSize="12"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="PROGRESS" Classes="Label" FontSize="10"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Progress.ProgressText}" Classes="Value" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <CheckBox IsChecked="{Binding Settings.UseGpu}" Content="Use GPU for Inference"/>
                                <TextBlock Text="Requires compatible NVIDIA/AMD GPU" Classes="Status" FontSize="10" Margin="24,0,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ FOOTER / ACTION BAR ═══ -->
        <Border Grid.Row="2" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Progress.FooterStatusText}" Classes="Status" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="■ CANCEL" Classes="Danger" IsVisible="{Binding IsSorting}" Command="{Binding CancelSortCommand}"/>
                    <Button Content="▶ START SORT" Classes="Primary" MinWidth="140" IsVisible="{Binding IsNotSorting}" Command="{Binding StartSortCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>