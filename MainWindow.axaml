<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sorter.ViewModels"
        xmlns:conv="using:Avalonia.Data.Converters"
        x:Class="Sorter.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Sorterz — AI Image Organizer"
        Width="1400" Height="860"
        MaxWidth="1920"
        MinWidth="1000" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#0D0F14"
        Icon="/Assets/Icon.ico">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,10">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image Source="/Assets/logo64.png" Height="32" Width="32"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SORTER" Classes="Heading" FontSize="20"/>
                        <TextBlock Text="AI-POWERED IMAGE ORGANIZER" Classes="Label" FontSize="10" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Center: connection status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{Binding Connection.ConnectionColor}" VerticalAlignment="Center"/>
                    <TextBlock Classes="Status" FontSize="10" Text="{Binding Connection.ConnectionStatusText}"/>
                    <TextBlock Classes="Status" FontSize="10" Text="|" Opacity="0.4"/>
                    <TextBlock Classes="Status" FontSize="10">
                        <Run Text="BACKEND: "/>
                        <Run Text="{Binding Settings.ActiveBackend}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Right: icon buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="Secondary" Padding="7,6" ToolTip.Tip="View on GitHub"
                            Command="{Binding OpenGitHubCommand}">
                        <Canvas Width="16" Height="16">
                            <Path Fill="#C8D0DC"
                                  Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                                        0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
                                        -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
                                        .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
                                        -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27
                                        .68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
                                        .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
                                        0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8
                                        C16 3.58 12.42 0 8 0z"/>
                        </Canvas>
                    </Button>
                    <Button Classes="Secondary" Padding="7,6" ToolTip.Tip="Open settings folder"
                            Command="{Binding OpenSettingsFolderCommand}">
                        <Canvas Width="16" Height="16">
                            <Path Fill="#C8D0DC"
                                  Data="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z
                                        M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319z"/>
                        </Canvas>
                    </Button>
                    <Button Classes="Secondary" Padding="7,6" ToolTip.Tip="Reload settings from disk"
                            Command="{Binding ReloadSettingsCommand}">
                        <Canvas Width="16" Height="16">
                            <Path Fill="#C8D0DC"
                                  Data="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z
                                        M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/>
                        </Canvas>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="290,*,310">

            <!-- ═══ LEFT PANEL ═══ -->
            <Border Grid.Column="0" Background="#0D0F14" BorderBrush="#1E2430" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14" Spacing="11">

                        <!-- FOLDERS -->
                        <Border Classes="Card">
                            <StackPanel Spacing="9">
                                <TextBlock Text="FOLDERS" Classes="Label"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="SOURCE (to sort)" Classes="Label" FontSize="10"/>
                                    <Grid ColumnDefinitions="*,6,Auto">
                                        <TextBox Text="{Binding Settings.SortingFolder}" Grid.Column="0" Watermark="C:\path\to\source..."/>
                                        <Button Grid.Column="2" Content="···" Classes="Secondary" Padding="10,6" Command="{Binding BrowseSourceCommand}"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="OUTPUT (sorted into)" Classes="Label" FontSize="10"/>
                                    <Grid ColumnDefinitions="*,6,Auto">
                                        <TextBox Text="{Binding Settings.SortedFolder}" Grid.Column="0" Watermark="C:\path\to\output..."/>
                                        <Button Grid.Column="2" Content="···" Classes="Secondary" Padding="10,6" Command="{Binding BrowseOutputCommand}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- RENAME OPTIONS -->
                        <Border Classes="Card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="RENAME OPTIONS" Classes="Label"/>
                                <CheckBox IsChecked="{Binding Settings.UsePrefix}" Content="Use Prefix on Rename"/>
                                <StackPanel Spacing="4" IsVisible="{Binding Settings.UsePrefix}">
                                    <TextBlock Text="PREFIX (max 8 chars)" Classes="Label" FontSize="10"/>
                                    <TextBox Text="{Binding Settings.Prefix}" MaxLength="8" Watermark="IMG"/>
                                    <TextBlock Text="Format: PREFIX.YEAR.MM.DD.desc.ext" Classes="Status" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Text="Format: YEAR.MM.DD.three.word.desc.ext"
                                           Classes="Status" FontSize="10" TextWrapping="Wrap"
                                           IsVisible="{Binding Settings.UsePrefix, Converter={x:Static conv:BoolConverters.Not}}"/>
                            </StackPanel>
                        </Border>

                        <!-- FILTER OPTIONS -->
                        <Border Classes="Card">
                            <StackPanel Spacing="7">
                                <TextBlock Text="FILTER OPTIONS" Classes="Label"/>
                                <CheckBox IsChecked="{Binding Settings.IgnoreNonDatedFiles}" Content="Ignore non-dated files"/>
                                <TextBlock Text="Skips files with no date in 2001–2099 range"
                                           Classes="Status" FontSize="10" Margin="24,0,0,3" TextWrapping="Wrap"/>
                                <CheckBox IsChecked="{Binding Settings.UseSubfolders}" Content="Sort into description subfolders"/>
                                <TextBlock Text="AI creates a subfolder per image description"
                                           Classes="Status" FontSize="10" Margin="24,0,0,3" TextWrapping="Wrap"/>
                                <CheckBox IsChecked="{Binding Settings.EraseExif}" Content="Erase existing EXIF data"/>
                                <TextBlock Text="Strips EXIF metadata from JPEG files before moving"
                                           Classes="Status" FontSize="10" Margin="24,0,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- IMAGE PREVIEW — 3:2 ratio container -->
                        <Border Classes="Card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="CURRENT IMAGE PREVIEW" Classes="Label"/>
                                <!-- 3:2 aspect ratio: Width fills container, Height = Width * 2/3.
                                     We use a fixed height that approximates 3:2 for the 258px wide card interior.
                                     Stretch="Uniform" keeps the image's own aspect ratio intact inside the 3:2 box. -->
                                <Border BorderBrush="#2A3040" BorderThickness="1" CornerRadius="4"
                                        ClipToBounds="True" Background="#12141A"
                                        Height="172">
                                    <Panel>
                                        <TextBlock Text="No Image Loaded"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Foreground="#444444" FontSize="11"
                                                   IsVisible="{Binding Preview.HasImage, Converter={x:Static conv:BoolConverters.Not}}"/>
                                        <Image Source="{Binding Preview.CurrentImageSource}"
                                               Stretch="Uniform"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                    </Panel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══ MIDDLE PANEL ═══ -->
            <Grid Grid.Column="1" RowDefinitions="Auto,4,Auto,Auto,*,Auto,140">

                <!-- Row 0: Backend + Server buttons -->
                <Border Grid.Row="0" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,0,0,1" Padding="12,9">
                    <StackPanel Spacing="7">
                        <!-- Platform selector buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <Button Command="{Binding SelectLmStudioCommand}"
                                    Classes.BackendActive="{Binding Settings.IsLmStudioSelected}"
                                    Classes.BackendIdle="{Binding Settings.IsLmStudioSelected, Converter={x:Static conv:BoolConverters.Not}}"
                                    MinWidth="130" Padding="10,6" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Use LM Studio (local). Click to install if not found.">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                             Fill="{Binding Settings.LmStudioDetected, FallbackValue=DimGray}"/>
                                    <TextBlock Text="LM STUDIO" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SelectOllamaCommand}"
                                    Classes.BackendActive="{Binding Settings.IsOllamaSelected}"
                                    Classes.BackendIdle="{Binding Settings.IsOllamaSelected, Converter={x:Static conv:BoolConverters.Not}}"
                                    MinWidth="120" Padding="10,6" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Use Ollama (local). Click to install if not found.">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                             Fill="{Binding Settings.OllamaDetected, FallbackValue=DimGray}"/>
                                    <TextBlock Text="OLLAMA" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SelectCustomCommand}"
                                    Classes.BackendCustomActive="{Binding Settings.IsCustomSelected}"
                                    Classes.BackendCustomIdle="{Binding Settings.IsCustomSelected, Converter={x:Static conv:BoolConverters.Not}}"
                                    MinWidth="110" Padding="10,6" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Use a custom/external API endpoint">
                                <TextBlock Text="CUSTOM" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                        <!-- Server action buttons -->
                        <Grid ColumnDefinitions="*,6,*,6,*">
                            <Button Grid.Column="0"
                                    Content="{Binding Connection.ServerButtonText}"
                                    Background="{Binding Connection.ServerButtonBackground}"
                                    Foreground="White"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    FontSize="11" Padding="8,5"
                                    Command="{Binding LoadLmStudioCommand}"/>
                            <Button Grid.Column="2"
                                    Content="TEST CONNECTION"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    FontSize="11" Padding="8,5"
                                    Command="{Binding TestConnectionCommand}"/>
                            <Button Grid.Column="4"
                                    Content="STOP SERVER" Classes="Danger"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    FontSize="11" Padding="8,5"
                                    Command="{Binding StopServerCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Row 1: GridSplitter -->
                <GridSplitter Grid.Row="1" ResizeDirection="Rows" Background="#1E2430"
                              HorizontalAlignment="Stretch" Height="4"/>

                <!-- Row 2: Prompt header + checkboxes -->
                <Border Grid.Row="2" Classes="SectionHeader" BorderBrush="#1E2430" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,20,Auto,*,Auto">
                        <!-- Custom Prompt checkbox -->
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding Settings.UseCustomPrompt}"
                                      Content="CUSTOM PROMPT"
                                      FontFamily="Consolas,'Courier New',monospace"
                                      FontSize="11" Foreground="#6A7888"/>
                            <TextBlock Text="Create your own prompt"
                                       Classes="Status" FontSize="9" Margin="24,0,0,0"/>
                        </StackPanel>
                        <!-- Video Game Preset checkbox -->
                        <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding Settings.UseVrcPreset}"
                                      Content="VIDEO GAME PRESET"
                                      FontFamily="Consolas,'Courier New',monospace"
                                      FontSize="11" Foreground="#9A70D0">
                                <CheckBox.Styles>
                                    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
                                        <Setter Property="Background" Value="#9A70D0"/>
                                        <Setter Property="BorderBrush" Value="#9A70D0"/>
                                    </Style>
                                </CheckBox.Styles>
                            </CheckBox>
                            <TextBlock Text="VR/Digital Preset"
                                       Classes="Status" FontSize="9" Margin="24,0,0,0" Foreground="#7A5090"/>
                        </StackPanel>
                        <TextBlock Grid.Column="4" Text="(default shown when off)"
                                   Classes="Status" FontSize="10" VerticalAlignment="Center"
                                   IsVisible="{Binding Settings.IsDefaultPromptActive}"/>
                    </Grid>
                </Border>

                <!-- Row 3: Prompt text area — fixed height -->
                <Border Grid.Row="3" Background="#0A0C10" Height="110">
                    <Panel>
                        <TextBox Text="{Binding Settings.ActivePromptText, Mode=TwoWay}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 IsEnabled="{Binding Settings.UseCustomPrompt}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="#0A0C10" Foreground="#C8D0DC"
                                 BorderThickness="0" Padding="12,8"
                                 FontSize="11" FontFamily="Consolas,'Courier New',monospace"/>
                        <Border Background="#0A0C10" Opacity="0.6" IsHitTestVisible="False"
                                IsVisible="{Binding Settings.UseCustomPrompt, Converter={x:Static conv:BoolConverters.Not}}"/>
                    </Panel>
                </Border>

                <!-- Row 4: Activity Log (fills remaining space) -->
                <Border Grid.Row="4" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,1,0,0">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="SectionHeader" Grid.Row="0" BorderBrush="#1E2430" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Text="ACTIVITY LOG" Classes="Label" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="CLEAR" Classes="Secondary"
                                        Padding="8,3" FontSize="11" Command="{Binding ClearLogCommand}" Margin="0,0,5,0"/>
                                <Button Grid.Column="2" Content="RESET SETTINGS" Classes="Secondary"
                                        Padding="8,3" FontSize="11" Command="{Binding ResetSettingsCommand}"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ListBox ItemsSource="{Binding Progress.LogEntries}"
                                     Background="Transparent" BorderThickness="0" Margin="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                   FontFamily="Consolas,'Courier New',monospace"
                                                   FontSize="11" Foreground="#7888A0"
                                                   Padding="4,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Row 5: Progress bar -->
                <Border Grid.Row="5" Background="#0D0F14" Padding="14,7" BorderBrush="#1E2430" BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <ProgressBar Grid.Row="0" Grid.ColumnSpan="2" Minimum="0" Maximum="100"
                                     Value="{Binding Progress.ProgressValue}" Height="5" Margin="0,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Progress.StatusText}" Classes="Status" FontSize="11"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Progress.ProgressText}" Classes="Value" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Row 6: Processed files -->
                <Border Grid.Row="6" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,1,0,0">
                    <Grid RowDefinitions="Auto,*">
                        <Border Classes="SectionHeader" Grid.Row="0">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="PROCESSED FILES" Classes="Label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Progress.ResultCountText}" Grid.Column="1"
                                           Classes="Value" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ListBox ItemsSource="{Binding Progress.ProcessedFiles}"
                                     Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                   FontFamily="Consolas,'Courier New',monospace"
                                                   FontSize="11" Foreground="#7888A0"
                                                   Padding="4,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Border>

            </Grid>

            <!-- ═══ RIGHT PANEL ═══ -->
            <Border Grid.Column="2" Background="#0D0F14" BorderBrush="#1E2430" BorderThickness="1,0,0,1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14" Spacing="11">

                        <!-- API ENDPOINT -->
                        <Border Classes="Card">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="Label">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="API ENDPOINT ({0})">
                                            <Binding Path="Settings.ActiveBackend"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBox Text="{Binding Settings.LmStudioUrl}"
                                         IsVisible="{Binding Settings.IsOllamaSelected, Converter={x:Static conv:BoolConverters.Not}}"
                                         FontSize="11" Padding="8,6" Background="#161A22" BorderBrush="#2A3040"/>
                                <TextBox Text="{Binding Settings.OllamaUrl}"
                                         IsVisible="{Binding Settings.IsOllamaSelected}"
                                         FontSize="11" Padding="8,6" Background="#161A22" BorderBrush="#2A3040"/>
                            </StackPanel>
                        </Border>

                        <!-- MODEL SELECTION -->
                        <Border Classes="Card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="MODEL SELECTION" Classes="Label"/>
                                <TextBlock Text="Select a vision model. VRAM shown per model."
                                           Classes="Status" FontSize="9" TextWrapping="Wrap"/>

                                <!-- Dropdown shows model URL on hover when not Custom -->
                                <ComboBox SelectedItem="{Binding Settings.SelectedModelEntry}"
                                          ItemsSource="{Binding Settings.AvailableModels}"
                                          HorizontalAlignment="Stretch" FontSize="11"
                                          Background="#161A22" Foreground="#E8C55A"
                                          ToolTip.Tip="{Binding Settings.SelectedModelUrl}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModelEntry">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                       FontFamily="Consolas,'Courier New',monospace"
                                                       Foreground="#C8D0DC"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- Custom model input -->
                                <StackPanel Spacing="4" IsVisible="{Binding Settings.IsCustomModelSelected}">
                                    <TextBlock Text="CUSTOM MODEL ID" Classes="Label" FontSize="10"/>
                                    <TextBox Text="{Binding Settings.CustomModelName}"
                                             Watermark="e.g. org/model-GGUF or ollama-tag:7b"
                                             FontSize="11"
                                             IsEnabled="{Binding Settings.IsCustomModelSelected}"/>
                                    <TextBlock Text="Saved to settings.json in AppData"
                                               Classes="Status" FontSize="9" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Button Content="INSTALL MODEL"
                                        Background="#228B22" Foreground="White"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Command="{Binding InstallLmStudioCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- CONTEXT / TOKEN SETTINGS -->
                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="CONTEXT / TOKEN SETTINGS" Classes="Label"/>

                                <!-- Temperature -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="TEMPERATURE" Classes="Label" FontSize="10"/>
                                        <TextBlock Classes="Status" FontSize="9" TextWrapping="Wrap"
                                                   Text="Controls randomness / creativity of output"/>
                                        <TextBlock Classes="Status" FontSize="9" TextWrapping="Wrap"
                                                   Text="Lower = focused, Higher = creative"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Settings.Temperature}"
                                             Width="72" FontSize="11" Padding="6,4"
                                             VerticalAlignment="Top"
                                             Background="#161A22" BorderBrush="#2A3040"
                                             ToolTip.Tip="Controls the 'randomness' or creativity of the output. A lower temperature makes the model less creative, while a higher temperature makes it more creative or imaginative."/>
                                </Grid>

                                <Separator Background="#1E2430" Height="1" Margin="0,2"/>

                                <!-- Top-P -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="TOP-P" Classes="Label" FontSize="10"/>
                                        <TextBlock Classes="Status" FontSize="9" TextWrapping="Wrap"
                                                   Text="Selects from high-probability words only"/>
                                        <TextBlock Classes="Status" FontSize="9" TextWrapping="Wrap"
                                                   Text="Lower = restricted, Higher = wider vocabulary"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Settings.TopP}"
                                             Width="72" FontSize="11" Padding="6,4"
                                             VerticalAlignment="Top"
                                             Background="#161A22" BorderBrush="#2A3040"
                                             ToolTip.Tip="Selects from a smaller subset of high-probability words. A lower value restricts to only the most likely word, while a high value has a larger vocabulary."/>
                                </Grid>

                                <Separator Background="#1E2430" Height="1" Margin="0,2"/>

                                <!-- Max Tokens -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="MAX TOKENS" Classes="Label" FontSize="10"/>
                                        <TextBlock Classes="Status" FontSize="9" TextWrapping="Wrap"
                                                   Text="Limits words the model can generate"/>
                                        <TextBlock Classes="Status" FontSize="9" TextWrapping="Wrap"
                                                   Text="0 = model default  |  Lower = less rambling"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Settings.MaxTokens}"
                                             Width="72" FontSize="11" Padding="6,4"
                                             VerticalAlignment="Top"
                                             Background="#161A22" BorderBrush="#2A3040"
                                             ToolTip.Tip="Sets a limit on number of tokens (words) the model generates. Having lower values prevents the model from rambling."/>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <!-- TOKEN COST / SPEED -->
                        <Border Classes="Card">
                            <StackPanel Spacing="8">
                                <CheckBox IsChecked="{Binding Settings.ShowTokenCost}" Content="Show Token Cost / Speed"/>
                                <Border Background="#0D0F14" BorderBrush="#1E2430" BorderThickness="1"
                                        CornerRadius="4" Padding="10,8"
                                        IsVisible="{Binding Settings.ShowTokenCost}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="INPUT TOKENS"  Classes="Label" FontSize="10" Margin="0,0,0,5"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Progress.InputTokens}"     Classes="Value" FontSize="12"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="OUTPUT TOKENS" Classes="Label" FontSize="10" Margin="0,0,0,5"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Progress.OutputTokens}"    Classes="Value" FontSize="12"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="SPEED (t/s)"   Classes="Label" FontSize="10" Margin="0,0,0,5"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Progress.TokensPerSecond}" Classes="Value" FontSize="12"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="PROGRESS"      Classes="Label" FontSize="10"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Progress.ProgressText}"    Classes="Value" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- SAFETY OPTIONS -->
                        <Border Classes="Card">
                            <StackPanel Spacing="8">
                                <TextBlock Text="SAFETY OPTIONS" Classes="Label"/>
                                <CheckBox IsChecked="{Binding Settings.UseGpu}" Content="Use GPU for Inference"/>
                                <TextBlock Text="Requires compatible NVIDIA/AMD GPU"
                                           Classes="Status" FontSize="10" Margin="24,0,0,5" TextWrapping="Wrap"/>
                                <CheckBox IsChecked="{Binding Settings.LimitServer}"
                                          Content="LIMIT SERVER"
                                          ToolTip.Tip="Ensures only one LLM server is active. When checked, stops all other running LLMs and starts only the currently selected model on the selected backend."/>
                                <TextBlock Text="Stops all other LLMs; runs only your selected model"
                                           Classes="Status" FontSize="9" Margin="24,0,0,0" TextWrapping="Wrap"
                                           IsVisible="{Binding Settings.LimitServer}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="2" Background="#0A0C10" BorderBrush="#1E2430" BorderThickness="0,1,0,0" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding Progress.FooterStatusText}"
                           Classes="Status" VerticalAlignment="Center" FontSize="12"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Content="■ CANCEL" Classes="Danger"
                            Padding="18,10" FontSize="13"
                            IsVisible="{Binding IsSorting}" Command="{Binding CancelSortCommand}"/>
                    <Button Content="▶  START SORT" Classes="Primary"
                            MinWidth="180" Padding="20,12" FontSize="14" FontWeight="Bold"
                            IsVisible="{Binding IsNotSorting}" Command="{Binding StartSortCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
