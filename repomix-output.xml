<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converter="using:Sorter.Converters">

    <!-- Add this converter definition to the top of your styles file if you use a converter class, 
         OR we can use a simpler approach by binding directly to a Color property in the ViewModel.
         To keep things simple and avoid adding new files, I will provide the updated Styles 
         and the updated ViewModel below using the direct property approach. -->

    <!-- Dark industrial theme with amber accents -->
    <Style Selector="Window">
        <Setter Property="Background" Value="#0D0F14"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="#C8D0DC"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#161A22"/>
        <Setter Property="Foreground" Value="#E8C55A"/>
        <Setter Property="BorderBrush" Value="#2A3040"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="FontFamily" Value="Consolas, 'Courier New', monospace"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="#E8C55A"/>
    </Style>

    <Style Selector="Button.Primary">
