                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14">
                    <Image Source="/Assets/logo64.png" Height="32" Width="32"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SORTER" Classes="Heading" FontSize="20"/>
                        <TextBlock Text="AI-POWERED IMAGE ORGANIZER" Classes="Label" FontSize="11" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- Connection Status is now bound to ViewModel -->
                    <Ellipse x:Name="ConnectionIndicator" Width="8" Height="8" Fill="#3A4050"/>
                    <TextBlock Text="{Binding ConnectionStatusText}" Classes="Label" VerticalAlignment="Center"/>
					 
                    <Button Content="TEST" 
                            Classes="Secondary" 
                            Padding="8,4" FontSize="11" 
                            Command="{Binding TestConnectionCommand}"/>

                    <Button Content="LM INSTALL" 
                            Background="#228B22" 
                            Foreground="White"
                            Padding="24,4" 
                            FontSize="11" 
                            Command="{Binding InstallLmStudioCommand}"/>

                    <Button Content="START LM SERVER" 
                            Background="#228B22" 
                            Foreground="White"
                            Padding="24,4" 
                            FontSize="11" 
                            Command="{Binding LoadLmStudioCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="300,*">

            <!-- ═══ LEFT PANEL: CONTROLS ═══ -->
            <Border Grid.Column="0" Background="#0D0F14" BorderBrush="#1E2430" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" Spacing="14">

                        <!-- FOLDERS CARD -->
                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="FOLDERS" Classes="Label"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="SOURCE (to sort)" Classes="Label" FontSize="10"/>
                                    <Grid ColumnDefinitions="*,6,Auto">
                                        <TextBox Text="{Binding SortingFolder}" Grid.Column="0" Watermark="C:\path\to\source..."/>
                                        <Button Grid.Column="2" Content="···" Classes="Secondary"
