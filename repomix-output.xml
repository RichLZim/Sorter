                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="OUTPUT (sorted into)" Classes="Label" FontSize="10"/>
                                    <Grid ColumnDefinitions="*,6,Auto">
                                        <TextBox Text="{Binding SortedFolder}" Grid.Column="0" Watermark="C:\path\to\output..."/>
                                        <Button Grid.Column="2" Content="···" Classes="Secondary"
                                                Padding="10,6" Command="{Binding BrowseOutputCommand}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- LM STUDIO SETTINGS CARD -->
                        <Border Classes="Card">
                            <StackPanel Spacing="10">
                                <TextBlock Text="LM STUDIO" Classes="Label"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="SERVER URL" Classes="Label" FontSize="10"/>
                                    <TextBox Text="{Binding LmStudioUrl}"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="MODEL NAME" Classes="Label" FontSize="10"/>
                                    <TextBox Text="{Binding ModelName}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- RENAME OPTIONS CARD -->
